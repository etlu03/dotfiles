set auto-load safe-path / # current directory initialization

set disassembly-flavor att # att syntax assembly

set history save on # saves command history between sessions
set pagination off # set height limit to unlimited, and auto confirm

set logging on # enable logging
set logging overwrite on # overwrite log file

set print pretty on # displays values of classes, structs etc. nicely
set confirm off # auto confirms commands

set $limit = 10 # store limit in variable

set print elements limit
